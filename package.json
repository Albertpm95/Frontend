    "@angular/router": "^19.2.2",
    "@ngrx/effects": "^19.0.1",
    "@ngrx/operators": "^19.0.1",
    "@ngrx/signals": "^19.0.1",
    "@ngrx/store": "^19.0.1",
    "@ngrx/store-devtools": "^19.0.1",
    "@tailwindcss/postcss": "^4.0.14",
    "postcss": "^8.5.3",
    "rxjs": "~7.8.2",
    "tailwindcss": "^4.0.14",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.3",
    "@angular/cli": "^19.2.3",
    "@angular/compiler-cli": "^19.2.2",
    "@biomejs/biome": "1.9.4",
